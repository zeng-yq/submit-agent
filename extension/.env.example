# Default LLM configuration (built into the extension at build time)
# Users can override these in the extension Settings UI
#
# Default uses Groq free tier (https://console.groq.com)
DEFAULT_LLM_BASE_URL=https://api.groq.com/openai/v1
DEFAULT_LLM_API_KEY=your_groq_api_key_here
DEFAULT_LLM_MODEL=llama-3.3-70b-versatile